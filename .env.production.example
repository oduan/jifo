POSTGRES_USER=jifo
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=jifo
JWT_SECRET=replace-with-at-least-32-random-bytes
HTTP_PORT=8080
POSTGRES_PORT=5432
JIFO_SUBNET=172.30.0.0/24

# Defaults to the private Compose subnet so Nginx can forward the real client IP.
TRUSTED_PROXIES=172.30.0.0/24

AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=1m
ACCESS_TOKEN_TTL=15m
CLEANUP_INTERVAL=1h
CLEANUP_TIMEOUT=10m
