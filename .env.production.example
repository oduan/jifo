POSTGRES_USER=jifo
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=jifo
JWT_SECRET=replace-with-at-least-32-random-bytes
API_PORT=8080

# Only configure addresses/CIDRs that can connect directly to the API container.
# Example when the trusted reverse proxy is on a known Docker network:
# TRUSTED_PROXIES=172.30.0.10/32
TRUSTED_PROXIES=

AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=1m
ACCESS_TOKEN_TTL=15m
CLEANUP_INTERVAL=1h
CLEANUP_TIMEOUT=10m
