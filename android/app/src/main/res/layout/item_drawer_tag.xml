<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="34dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="4dp">

    <Space
        android:id="@+id/tag_indent"
        android:layout_width="0dp"
        android:layout_height="1dp" />

    <TextView
        android:id="@+id/text_hash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#"
        android:textColor="@color/jifo_tag_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_tag_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="@color/jifo_ink"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/button_expand_tag"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:background="@android:color/transparent"
        android:contentDescription="展开标签"
        android:padding="5dp"
        android:visibility="gone" />
</LinearLayout>
