<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    android:orientation="vertical"
    android:background="@drawable/bg_note_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_note_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/jifo_muted"
            android:textSize="11sp" />

        <ImageButton
            android:id="@+id/button_note_more"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@android:color/transparent"
            android:contentDescription="更多操作"
            android:padding="4dp"
            android:src="@drawable/ic_more_vert_24" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_note_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#3A322A"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />
</LinearLayout>
